# Deps
node_modules
.deno

# Output
/target
/.svelte-kit
/build
/dist
/dist_*
/.gro
/.zzz

# WASM build output
/crates/tsv_wasm/pkg

# Publish retry sentinel (scripts/publish.ts)
/.publish-in-progress

# Drift-check generated file (left on failure for inspection)
/scripts/.drift_check.gen.ts

# Derived corpus caches (regenerable — e.g. the wpt <style> harvest from
# benches/js/diagnostics/wpt_css_harvest.ts)
/benches/js/.cache

# Benchmark results (the per-runtime report.<runtime>.{json,md} siblings, their
# conformance-surface siblings report.conformance.<runtime>.{json,md}, and the
# combined report.{json,md} are committed; timestamped runs + baseline.json are
# gitignored)
/benches/js/results/*.json
/benches/js/results/*.md
!/benches/js/results/report.deno.json
!/benches/js/results/report.deno.md
!/benches/js/results/report.node.json
!/benches/js/results/report.node.md
!/benches/js/results/report.bun.json
!/benches/js/results/report.bun.md
!/benches/js/results/report.conformance.deno.json
!/benches/js/results/report.conformance.deno.md
!/benches/js/results/report.conformance.node.json
!/benches/js/results/report.conformance.node.md
!/benches/js/results/report.conformance.bun.json
!/benches/js/results/report.conformance.bun.md
!/benches/js/results/report.json
!/benches/js/results/report.md

# Env
.env*
!.env.example
!.env.*.example
!.env.test
!.env.*.test

# Secrets
*.pem
id_rsa

# Local (per-machine, never shared)
*.local
*.local.*

# Ignore
*.ignore
*.ignore.*
ignore

# Temporary files
tmp/
*.tmp
.tmp*
*.bak

# Log files
*.log

# Workflow
/worktree

# Os
.DS_Store
Thumbs.db
