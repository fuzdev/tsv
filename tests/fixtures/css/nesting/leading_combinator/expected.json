			"styles": "\n\t.class1 {\n\t\tpadding: 10px;\n\n\t\t/* child combinator */\n\t\t> .class2 {\n\t\t\tmargin: 5px;\n\t\t}\n\n\t\t/* next-sibling combinator */\n\t\t+ .class3 {\n\t\t\tmargin-top: 20px;\n\t\t}\n\n\t\t/* subsequent-sibling combinator */\n\t\t~ .class4 {\n\t\t\tcolor: gray;\n\t\t}\n\n\t\t/* leading combinator in selector list */\n\t\t> .class5 > .class6 .class7,\n\t\t.class8,\n\t\t.class9 ::selection {\n\t\t\tcolor: blue;\n\t\t}\n\n\t\t/* combinator with multiple compound selectors */\n\t\t> .class10.class11 {\n\t\t\tcolor: red;\n\t\t}\n\t}\n",
