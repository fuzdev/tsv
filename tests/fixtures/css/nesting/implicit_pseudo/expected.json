		"content": {
			"start": 7,
			"end": 426,
			"styles": "\n\t.class1 {\n\t\tcolor: red;\n\n\t\tspan:hover {\n\t\t\tcolor: blue;\n\t\t}\n\n\t\ta:not(:last-child) {\n\t\t\tcolor: green;\n\t\t}\n\n\t\tspan:not(:last-child)::after {\n\t\t\tcontent: ' > ';\n\t\t}\n\n\t\tdiv:first-child {\n\t\t\tmargin: 0;\n\t\t}\n\n\t\tp:nth-child(2n + 1) {\n\t\t\tbackground: red;\n\t\t}\n\n\t\t/* Type selector with pseudo inside nested @media */\n\t\t@media (min-width: 800px) {\n\t\t\th2 {\n\t\t\t\tfont-size: 2rem;\n\t\t\t}\n\n\t\t\tspan:hover {\n\t\t\t\tcolor: green;\n\t\t\t}\n\t\t}\n\t}\n",
