		"content": {
			"start": 7,
			"end": 1108,
			"styles": "\n\t/* Basic scoping */\n\t@scope (.class1) {\n\t\timg {\n\t\t\tborder: 1px solid;\n\t\t}\n\t}\n\n\t/* Scope with limit */\n\t@scope (.class1) to (.class2) {\n\t\tp {\n\t\t\tcolor: blue;\n\t\t}\n\t}\n\n\t/* Named scope root */\n\t@scope (#id1) {\n\t\th1 {\n\t\t\tfont-size: 2rem;\n\t\t}\n\t}\n\n\t/* Scope with multiple selectors */\n\t@scope (.class1, .class3) {\n\t\t.class4 {\n\t\t\tfont-weight: bold;\n\t\t}\n\t}\n\n\t/* Scope with complex limit */\n\t@scope (.class5) to (.class6, .class7) {\n\t\ta {\n\t\t\ttext-decoration: underline;\n\t\t}\n\t}\n\n\t/* Nested scopes */\n\t@scope (.outer) {\n\t\t.outer-content {\n\t\t\tpadding: 1rem;\n\t\t}\n\n\t\t@scope (.inner) {\n\t\t\tspan {\n\t\t\t\tfont-weight: bold;\n\t\t\t}\n\t\t}\n\t}\n\n\t/* Scope with descendant selectors */\n\t@scope (article > header) {\n\t\th2 {\n\t\t\tmargin: 0;\n\t\t}\n\t}\n\n\t/* Scope with pseudo-class */\n\t@scope (.class8:hover) {\n\t\t.class9 {\n\t\t\tdisplay: block;\n\t\t}\n\t}\n\n\t/* Scope with limit and nested rules */\n\t@scope (.class10) to (.class11) {\n\t\tsection {\n\t\t\tmargin-bottom: 2rem;\n\t\t}\n\n\t\t.class12 {\n\t\t\tposition: sticky;\n\t\t}\n\t}\n\n\t/* Scope with attribute selector */\n\t@scope ([data-theme='dark']) {\n\t\t.background {\n\t\t\tbackground: black;\n\t\t\tcolor: white;\n\t\t}\n\t}\n",
			"comment": null
		}
	},
