		"content": {
			"start": 7,
			"end": 859,
			"styles": "\n\t/* Single comparison operators (MQ Level 4) */\n\t@media (width >= 768px) {\n\t\t.desktop {\n\t\t\tfont-size: 16px;\n\t\t}\n\t}\n\n\t@media (width > 600px) {\n\t\t.medium {\n\t\t\tpadding: 2rem;\n\t\t}\n\t}\n\n\t@media (width <= 1200px) {\n\t\t.constrained {\n\t\t\tmax-width: 1200px;\n\t\t}\n\t}\n\n\t@media (width < 1400px) {\n\t\t.narrow {\n\t\t\tcolumns: 1;\n\t\t}\n\t}\n\n\t/* Range feature names */\n\t@media (height >= 600px) {\n\t\t.tall {\n\t\t\tmin-height: 100vh;\n\t\t}\n\t}\n\n\t@media (resolution >= 2dppx) {\n\t\t.retina {\n\t\t\timage-rendering: crisp-edges;\n\t\t}\n\t}\n\n\t/* Double comparison (range syntax) */\n\t@media (400px <= width <= 1200px) {\n\t\t.range {\n\t\t\tpadding: 1rem;\n\t\t}\n\t}\n\n\t/* Combined with boolean operators */\n\t@media (width >= 768px) and (width <= 1024px) {\n\t\t.tablet {\n\t\t\tdisplay: flex;\n\t\t}\n\t}\n\n\t@media (width > 1200px) or (orientation: landscape) {\n\t\t.wide {\n\t\t\tgrid-template-columns: repeat(3, 1fr);\n\t\t}\n\t}\n",
			"comment": null
		}
