		"content": {
			"start": 7,
			"end": 265,
			"styles": "\n\t/* comment spacing inside a forgiving list (:is/:where/:not/:has) normalizes to single spaces */\n\t:is(.a, /* mid */ .b) {\n\t\tcolor: red;\n\t}\n\n\t/* a comment before the comma keeps its side; spacing still normalizes */\n\t.c /* before */, .d {\n\t\tcolor: blue;\n\t}\n",
