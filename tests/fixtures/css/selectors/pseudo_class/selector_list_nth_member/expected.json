			"styles": "\n\t/* :is() forgiving list keeps a bare number as an Nth node (not dropped) */\n\t:is(.a, 123) {\n\t\tcolor: red;\n\t}\n\n\t/* :not() list: a bare An+B is an Nth node */\n\t:not(2n) {\n\t\tcolor: blue;\n\t}\n\n\t/* :has() relative list: a bare number is an Nth node */\n\t:has(123) {\n\t\tcolor: green;\n\t}\n",
