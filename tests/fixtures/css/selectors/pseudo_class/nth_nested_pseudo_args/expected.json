		"content": {
			"start": 7,
			"end": 242,
			"styles": "\n\t/* An+B classification is active in nested pseudo-class args, and restores */\n\t:is(:not(2n)) {\n\t\tcolor: red;\n\t}\n\n\t/* the flag restores between siblings: .a stays a class after the odd Nth */\n\t:where(:is(odd), .a) {\n\t\tcolor: blue;\n\t}\n",
			"comment": null
		}
