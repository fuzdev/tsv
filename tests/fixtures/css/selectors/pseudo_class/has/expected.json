		"content": {
			"start": 7,
			"end": 516,
			"styles": "\n\t/* Basic :has() with combinators */\n\ta:has(> img) {\n\t\tdisplay: block;\n\t}\n\n\tli:has(+ li) {\n\t\tmargin-bottom: 10px;\n\t}\n\n\t/* :has() with multiple selectors */\n\tarticle:has(h2, h3) {\n\t\tpadding: 20px;\n\t}\n\n\t/* :has() with negation */\n\tdiv:has(:not(.class1)) {\n\t\tbackground: lightgray;\n\t}\n\n\t/* Chained :has() */\n\tsection:has(> h2):has(> p) {\n\t\tborder: 1px solid red;\n\t}\n\n\t/* :has() combined with :is() and :not() */\n\t:is(.class1, .class2):has(span) {\n\t\tcolor: blue;\n\t}\n\n\tdiv:not(:has(.class1)) {\n\t\topacity: 0.5;\n\t}\n",
			"comment": null
		}
	},
