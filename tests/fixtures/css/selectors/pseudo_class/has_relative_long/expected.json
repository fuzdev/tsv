		"content": {
			"start": 7,
			"end": 377,
			"styles": "\n\t/* :has() with relative (leading-combinator) selectors — short, stays inline */\n\tdiv:has(> .a, + .b, ~ .c) {\n\t\tcolor: red;\n\t}\n\t/* :has() relative selectors wrap one-per-line; each broken arg keeps its leading combinator */\n\tdiv:has(\n\t\t> .aaaaaaaaaaaa,\n\t\t+ .bbbbbbbbbbbb,\n\t\t~ .cccccccccccc,\n\t\t> .dddddddddddd,\n\t\t+ .eeeeeeeeeeee,\n\t\t~ .ffffffffffff\n\t) {\n\t\tcolor: red;\n\t}\n",
			"comment": null
		}
