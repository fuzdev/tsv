		"content": {
			"start": 7,
			"end": 436,
			"styles": "\n\t/* :is() - matches-any pseudo-class */\n\t.class1:is(.class2, .class3) {\n\t\tcolor: red;\n\t}\n\n\tdiv:is(#id1, #id2, .class1) {\n\t\tbackground: blue;\n\t}\n\n\t/* :where() - zero-specificity variant */\n\t:where(h1, h2, h3) {\n\t\tmargin: 10px;\n\t}\n\n\tarticle :where(h1, h2) {\n\t\tpadding: 5px;\n\t}\n\n\t/* :not() - negation pseudo-class */\n\tinput:not(.class4, [readonly]) {\n\t\tborder: 1px solid green;\n\t}\n\n\tdiv:not(#id1):not(.class1) {\n\t\topacity: 0.5;\n\t}\n",
			"comment": null
		}
