		"content": {
			"start": 7,
			"end": 987,
			"styles": "\n\tinput:checked {\n\t\tbackground: green;\n\t}\n\n\tbutton:disabled {\n\t\topacity: 0.5;\n\t\tcursor: not-allowed;\n\t}\n\n\tinput:enabled {\n\t\tborder-color: blue;\n\t}\n\n\tinput:focus {\n\t\toutline: 2px solid blue;\n\t}\n\n\ta:hover {\n\t\ttext-decoration: underline;\n\t}\n\n\ta:active {\n\t\tcolor: red;\n\t}\n\n\tinput:required {\n\t\tborder-left: 3px solid red;\n\t}\n\n\tinput:optional {\n\t\tborder-left: 3px solid gray;\n\t}\n\n\tinput:user-valid {\n\t\tborder-color: green;\n\t}\n\n\tinput:user-invalid {\n\t\tborder-color: red;\n\t}\n\n\tinput:autofill {\n\t\tbackground: lightyellow;\n\t}\n\n\tinput:valid {\n\t\tborder-color: green;\n\t}\n\n\tinput:invalid {\n\t\tborder-color: red;\n\t}\n\n\tinput:in-range {\n\t\tbackground: lightgreen;\n\t}\n\n\tinput:out-of-range {\n\t\tbackground: lightcoral;\n\t}\n\n\tinput:read-only {\n\t\tbackground: lightgray;\n\t}\n\n\tinput:read-write {\n\t\tbackground: white;\n\t}\n\n\tinput:placeholder-shown {\n\t\tcolor: gray;\n\t}\n\n\tbutton:default {\n\t\tfont-weight: bold;\n\t}\n\n\tinput:indeterminate {\n\t\topacity: 0.5;\n\t}\n\n\tbutton:focus-visible {\n\t\toutline: 2px solid blue;\n\t}\n",
