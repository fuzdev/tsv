			"styles": "\n\t/* Nested :where(:is()) - exceeds 100 chars, wraps with extra indent for complex selectors */\n\t:where(\n\t\t:is(\n\t\t\t\tp,\n\t\t\t\tul,\n\t\t\t\tol,\n\t\t\t\tmenu,\n\t\t\t\tform,\n\t\t\t\tfieldset,\n\t\t\t\ttable,\n\t\t\t\tdetails,\n\t\t\t\ttextarea,\n\t\t\t\tselect,\n\t\t\t\tlabel,\n\t\t\t\tpre,\n\t\t\t\tblockquote,\n\t\t\t\taside,\n\t\t\t\tnav\n\t\t\t):not(:last-child):not(.unstyled)\n\t) {\n\t\tmargin: 0;\n\t}\n",
