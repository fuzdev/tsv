		"content": {
			"start": 7,
			"end": 344,
			"styles": "\n\t/* Deeply nested logical combinations */\n\t:is(:is(.class1, .class2), :where(#id1, #id2)) {\n\t\tcolor: red;\n\t}\n\n\t:not(:is(.class1):not(.class2)) {\n\t\tbackground: blue;\n\t}\n\n\t/* All features combined */\n\tdiv:is(.class1, .class2):has(> span):not(.class3) {\n\t\tpadding: 10px;\n\t}\n\n\t:where(article, section):has(:is(h2, h3)) {\n\t\tmargin: 20px;\n\t}\n",
			"comment": null
		}
	},
