		"content": {
			"start": 7,
			"end": 305,
			"styles": "\n\t/* Leading -n An+B forms that Svelte's :nth-child reader mis-parses (as a type\n\t   selector, or a flattened type-selector + combinator chain), where tsv reads a\n\t   single Nth per the css-syntax-3 An+B microsyntax. */\n\ta:nth-child(-n) {\n\t\tcolor: red;\n\t}\n\n\ta:nth-child(-n - 3) {\n\t\tcolor: blue;\n\t}\n",
			"comment": null
		}
