		"content": {
			"start": 7,
			"end": 359,
			"styles": "\n\t/* Spec-valid negative An+B forms (css-syntax-3 An+B microsyntax): a bare negative\n\t   <integer> B, a negative <n-dimension> A, a negative A with a negative offset,\n\t   and negative-zero. */\n\ta:nth-child(-3) {\n\t\tcolor: red;\n\t}\n\n\ta:nth-child(-2n) {\n\t\tcolor: blue;\n\t}\n\n\ta:nth-child(-2n - 3) {\n\t\tcolor: green;\n\t}\n\n\ta:nth-child(-0) {\n\t\tcolor: yellow;\n\t}\n",
			"comment": null
		}
