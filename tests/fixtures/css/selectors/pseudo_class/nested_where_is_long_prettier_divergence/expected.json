		"content": {
			"start": 7,
			"end": 389,
			"styles": "\n\t/* Nested :where(:is()) exceeds 100 chars and wraps; the :is() args indent one\n\t   level (uniform), not the extra level prettier adds for a >2-node compound */\n\t:where(\n\t\t:is(\n\t\t\tp,\n\t\t\tul,\n\t\t\tol,\n\t\t\tmenu,\n\t\t\tform,\n\t\t\tfieldset,\n\t\t\ttable,\n\t\t\tdetails,\n\t\t\ttextarea,\n\t\t\tselect,\n\t\t\tlabel,\n\t\t\tpre,\n\t\t\tblockquote,\n\t\t\taside,\n\t\t\tnav\n\t\t):not(:last-child):not(.unstyled)\n\t) {\n\t\tmargin: 0;\n\t}\n",
			"comment": null
		}
