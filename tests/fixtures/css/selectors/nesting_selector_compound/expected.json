		"content": {
			"start": 7,
			"end": 564,
			"styles": "\n\t.class1 {\n\t\t/* type/ident attached to & forms one compound selector (no descendant space) */\n\t\t&__a {\n\t\t\tcolor: red;\n\t\t}\n\t\t&div {\n\t\t\tcolor: blue;\n\t\t}\n\t\tdiv& {\n\t\t\tcolor: green;\n\t\t}\n\t\t*& {\n\t\t\tcolor: orange;\n\t\t}\n\t\t&& {\n\t\t\tcolor: purple;\n\t\t}\n\t\ta&b {\n\t\t\tcolor: olive;\n\t\t}\n\t\t/* compound continues past the attached ident */\n\t\t&__a.class2:hover {\n\t\t\tmargin: 0;\n\t\t}\n\t\t/* whitespace keeps a real descendant combinator */\n\t\t& div {\n\t\t\tpadding: 0;\n\t\t}\n\t\t/* compound with class and pseudo-class */\n\t\t&.class3 {\n\t\t\tmargin: 0;\n\t\t}\n\t\t&:hover {\n\t\t\tdisplay: block;\n\t\t}\n\t}\n",
			"comment": null
		}
