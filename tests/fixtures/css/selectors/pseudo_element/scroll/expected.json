		"content": {
			"start": 7,
			"end": 549,
			"styles": "\n\t/* Scroll marker styling */\n\t::scroll-marker {\n\t\tbackground: blue;\n\t}\n\n\t/* Scroll marker group */\n\t::scroll-marker-group {\n\t\tpadding: 10px;\n\t}\n\n\t/* Scroll button with direction */\n\t::scroll-button(up) {\n\t\tborder-radius: 50%;\n\t}\n\n\t::scroll-button(down) {\n\t\tborder-radius: 50%;\n\t}\n\n\t::scroll-button(left) {\n\t\tborder-radius: 50%;\n\t}\n\n\t::scroll-button(right) {\n\t\tborder-radius: 50%;\n\t}\n\n\t/* Combined with selectors */\n\t.class1::scroll-marker {\n\t\tcolor: red;\n\t}\n\n\t/* With pseudo-class */\n\t.class1:hover::scroll-marker-group {\n\t\topacity: 0.8;\n\t}\n",
			"comment": null
		}
