		"content": {
			"start": 7,
			"end": 475,
			"styles": "\n\t/* bare number and An+B — the pseudo-arg Nth production */\n\t::slotted(0) {\n\t\tcolor: red;\n\t}\n\n\t::slotted(2n + 1) {\n\t\tcolor: blue;\n\t}\n\n\t/* descendant and child combinators — a full complex selector */\n\t::slotted(.class1 .class2) {\n\t\tcolor: green;\n\t}\n\n\t::slotted(.class1 > .class2) {\n\t\tcolor: yellow;\n\t}\n\n\t/* universal with a combinator */\n\t::slotted(* > *) {\n\t\tcolor: purple;\n\t}\n\n\t/* comma-separated selector list */\n\t::slotted(.class1, .class2) {\n\t\tcolor: orange;\n\t}\n",
			"comment": null
		}
