		"content": {
			"start": 7,
			"end": 619,
			"styles": "\n\t/* Short complex selectors - combinators stay inline (under 100 chars per selector) */\n\t.a > .b + .c ~ .d,\n\t.e > .f .g:hover,\n\t.h[data-x] > .i:first-child::before {\n\t\tcolor: red;\n\t}\n\n\t/* Long complex selectors - test combinator wrapping (>, +, ~, space) */\n\t.class1\n\t\t> .class2:not(.class3):hover\n\t\t> .class4\n\t\t+ .class5\n\t\t~ .class6[data-attr1][data-attr2]:first-child,\n\t#id1.class7.class8.class9\n\t\t> div.class10:nth-child(2n + 1)\n\t\tspan.class11:not(.class12):focus-within::before,\n\tarticle\n\t\t> section.class13\n\t\t> div.class14\n\t\t> p.class15\n\t\t> span.class16:where(.class17, .class18)::after {\n\t\tcolor: red;\n\t}\n",
			"comment": null
		}
