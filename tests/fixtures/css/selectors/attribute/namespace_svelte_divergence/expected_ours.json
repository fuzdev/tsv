		"content": {
			"start": 7,
			"end": 552,
			"styles": "\n\t/* Namespace prefix */\n\t[svg|href] {\n\t\tfill: red;\n\t}\n\n\t/* Universal namespace */\n\t[*|title] {\n\t\tcolor: blue;\n\t}\n\n\t/* Explicit no namespace */\n\t[|lang] {\n\t\tfont-weight: bold;\n\t}\n\n\t/* Implicit no namespace (default) */\n\t[class] {\n\t\tmargin: 0;\n\t}\n\n\t/* With matcher */\n\t[foo|att='val'] {\n\t\tcolor: green;\n\t}\n\n\t/* With matcher operators */\n\t[svg|href^='https'] {\n\t\ttext-decoration: underline;\n\t}\n\n\t/* Combined with other selectors */\n\tdiv[svg|href] {\n\t\tborder: 1px solid red;\n\t}\n\n\t/* Multiple attributes */\n\t[svg|href][*|title] {\n\t\topacity: 0.5;\n\t}\n",
			"comment": null
		}
