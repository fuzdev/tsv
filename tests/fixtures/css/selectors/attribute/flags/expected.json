		"content": {
			"start": 7,
			"end": 343,
			"styles": "\n\t/* Case-insensitive flag */\n\t[attr='value' i] {\n\t\tcolor: red;\n\t}\n\n\t/* Case-sensitive flag */\n\t[attr='value' s] {\n\t\tcolor: blue;\n\t}\n\n\t/* No flag (default) */\n\t[attr='value'] {\n\t\tcolor: green;\n\t}\n\n\t/* Flag with different operators */\n\t[href^='https' i] {\n\t\ttext-decoration: underline;\n\t}\n\t[title*='example' s] {\n\t\tfont-weight: bold;\n\t}\n",
