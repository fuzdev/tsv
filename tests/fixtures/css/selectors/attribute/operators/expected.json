		"content": {
			"start": 7,
			"end": 512,
			"styles": "\n\t/* Exact match */\n\t[attr='value'] {\n\t\tcolor: red;\n\t}\n\n\t/* Prefix match */\n\t[href^='https'] {\n\t\tcolor: blue;\n\t}\n\n\t/* Suffix match */\n\t[href$='.pdf'] {\n\t\tcolor: green;\n\t}\n\n\t/* Substring match */\n\t[title*='example'] {\n\t\tcolor: yellow;\n\t}\n\n\t/* Whitespace list contains */\n\t[class~='active'] {\n\t\tcolor: purple;\n\t}\n\n\t/* Dash prefix match */\n\t[lang|='en'] {\n\t\tcolor: orange;\n\t}\n\n\t/* Exact match, bare attribute selectors */\n\t[type='text'] {\n\t\tborder: 1px solid black;\n\t}\n\t[data-id='item'] {\n\t\tmargin: 10px;\n\t}\n",
