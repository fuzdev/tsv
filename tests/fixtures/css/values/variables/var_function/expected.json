		"content": {
			"start": 7,
			"end": 747,
			"styles": "\n\t:root {\n\t\t--prop1: #007bff;\n\t\t--prop2: #6c757d;\n\t\t--prop3: 16px;\n\t\t--prop4: 14px;\n\t}\n\n\t.class1 {\n\t\t/* Simple var() usage */\n\t\tcolor: var(--color1);\n\t\tbackground: var(--bg1);\n\t\tfont-size: var(--size1);\n\n\t\t/* var() with fallback */\n\t\tcolor: var(--color2, red);\n\t\tbackground: var(--bg2, #ffffff);\n\t\tmargin: var(--spacing1, 10px);\n\n\t\t/* Nested fallbacks (2 levels) */\n\t\tcolor: var(--color3, var(--color4, blue));\n\t\tpadding: var(--spacing2, var(--spacing3, 1rem));\n\n\t\t/* Multiple var() in one value */\n\t\tmargin: var(--top) var(--right) var(--bottom) var(--left);\n\t\tbox-shadow: var(--x) var(--y) var(--blur) var(--color);\n\n\t\t/* var() with complex fallbacks */\n\t\twidth: var(--width1, calc(100% - 2rem));\n\t\tcolor: var(--color5, rgb(255 0 0));\n\t}\n",
			"comment": null
		}
