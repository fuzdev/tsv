		"content": {
			"start": 7,
			"end": 657,
			"styles": "\n\tdiv {\n\t\t/* Basic calc() expressions */\n\t\twidth: calc(100% - 2rem);\n\t\theight: calc(50vh + 10px);\n\t\tmargin: calc(1em * 2);\n\t\tpadding: calc(20px / 4);\n\t\t/* Nested calc() */\n\t\tborder: calc(calc(10px + 5px) * 2);\n\t\toutline: calc(100% - calc(2rem + 10px));\n\t\t/* Mixed units */\n\t\ttop: calc(50vh - 10px);\n\t\tleft: calc(1em + 2px);\n\t\tright: calc(100% / 3 - 1rem);\n\t\t/* Complex expressions */\n\t\tmin-width: calc((100% - 40px) / 2);\n\t\tmin-height: calc(100vh - 60px - 2rem);\n\t\tmax-width: calc(1em + 0.5rem + 2px);\n\t\t/* Zero and negative values */\n\t\tz-index: calc(100% - 0);\n\t\torder: calc(0px + 50vh);\n\t\tflex: calc(-10px + 20px);\n\t\topacity: calc(100% + -5px);\n\t}\n",
