			"styles": "\n\tdiv {\n\t\t/* hsl() hue as an angle with explicit units (rad/turn/grad), space + comma syntax */\n\t\tcolor: hsl(2rad 50% 50%);\n\t\tbackground: hsl(0.5turn, 50%, 50%);\n\t\tborder-color: hsl(100grad 50% 50% / 0.5);\n\t\t/* deg is the common contrast case */\n\t\toutline-color: hsl(120deg 50% 50%);\n\t}\n",
