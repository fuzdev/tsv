		"content": {
			"start": 7,
			"end": 379,
			"styles": "\n\t/* :global() inside CSS nesting */\n\tdiv {\n\t\t:global(.class) {\n\t\t\tcolor: red;\n\t\t}\n\t}\n\n\t/* Nested with & combinator */\n\t.class {\n\t\t& :global(a) {\n\t\t\ttext-decoration: none;\n\t\t}\n\t}\n\n\t/* :global() as ancestor with & */\n\t.class1 {\n\t\t:global(.class2) & {\n\t\t\tbackground: blue;\n\t\t}\n\t}\n\n\t/* Deeply nested */\n\t.class1 {\n\t\t.class2 {\n\t\t\t:global(.class3) {\n\t\t\t\tmargin: 0;\n\t\t\t}\n\t\t}\n\t}\n",
			"comment": null
		}
