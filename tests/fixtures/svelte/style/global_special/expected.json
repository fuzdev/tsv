		"content": {
			"start": 7,
			"end": 403,
			"styles": "\n\t/* :global() with :root */\n\t:global(:root) {\n\t\t--color: red;\n\t}\n\n\t/* :global() with universal selector */\n\t:global(*) {\n\t\tbox-sizing: border-box;\n\t}\n\n\t/* :global() with html and body */\n\t:global(html),\n\t:global(body) {\n\t\tmargin: 0;\n\t}\n\n\t/* :global() with attribute selector */\n\t:global([data-attr]) {\n\t\tdisplay: block;\n\t}\n\n\t/* :global() with :not() */\n\t:global(:not(.class)) {\n\t\topacity: 1;\n\t}\n",
			"comment": null
		}
