			"styles": "\n\t/* :global() inside @media */\n\t@media (min-width: 768px) {\n\t\t:global(.class) {\n\t\t\tdisplay: block;\n\t\t}\n\t}\n\n\t/* :global() inside @supports */\n\t@supports (display: grid) {\n\t\t:global(.class) {\n\t\t\tdisplay: grid;\n\t\t}\n\t}\n\n\t/* :global() inside @layer */\n\t@layer base {\n\t\t:global(.class) {\n\t\t\tmargin: 0;\n\t\t}\n\t}\n\n\t/* :global() inside nested @media */\n\t@media screen {\n\t\t@media (min-width: 768px) {\n\t\t\t:global(.class) {\n\t\t\t\tpadding: 0;\n\t\t\t}\n\t\t}\n\t}\n",
