	"comments": [
		{
			"type": "Line",
			"value": " A constrained `infer U extends T` as a union member keeps its parens: without",
			"start": 20,
			"end": 100,
			"loc": {
				"start": {
					"line": 2,
					"column": 1
				},
				"end": {
					"line": 2,
					"column": 81
				}
			}
		},
		{
			"type": "Line",
			"value": " them the `extends` constraint greedily absorbs the following `| {…}`, widening",
			"start": 102,
			"end": 183,
			"loc": {
				"start": {
					"line": 3,
					"column": 1
				},
				"end": {
					"line": 3,
					"column": 82
				}
			}
		},
		{
			"type": "Line",
			"value": " the constraint from `number` to `number | {…}`.",
			"start": 185,
			"end": 235,
			"loc": {
				"start": {
					"line": 4,
					"column": 1
				},
				"end": {
					"line": 4,
					"column": 51
				}
			}
		},
		{
			"type": "Line",
			"value": " Same rule in the last position — prettier keeps the parens here too.",
			"start": 319,
			"end": 390,
			"loc": {
				"start": {
					"line": 7,
					"column": 1
				},
				"end": {
					"line": 7,
					"column": 72
				}
			}
		},
		{
			"type": "Line",
			"value": " Intersection member — same greedy `&` absorption, same required parens.",
			"start": 473,
			"end": 547,
			"loc": {
				"start": {
					"line": 10,
					"column": 1
				},
				"end": {
					"line": 10,
					"column": 75
				}
			}
		},
		{
			"type": "Line",
			"value": " Contrast: a bare `infer U` (no constraint) has nothing to absorb, so no parens.",
			"start": 726,
			"end": 808,
			"loc": {
				"start": {
					"line": 15,
					"column": 1
				},
